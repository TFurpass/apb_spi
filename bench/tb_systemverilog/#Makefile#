BUILD_DIR       = $(realpath $(CURDIR))/build
VERIL_BUILD_DIR = $(BUILD_DIR)/verilator_build
TOP_MODULE = tb_apb_spi

SRC_FILES          = $(shell bender script $(BENDER_FLAGS) flist-plus $(BENDER_TARGETS)) # runs a GNU shell command: generates simulator file list (flist-plus) which includes source files, include directories and compiler options, (script) tells bender to generate a script or file list. 

VDEFS = \
  +define+VERILATOR=1 


VFLAGS = \
	--timing \ # enables timing construct support in RTL i.e. delays and such.
	--trace-fst \ # waveform tracing generated in fst format (supported by gtkwave)
	--trace-structs \ # for structs, enables struct variables/logic/signals to be seen in waveform
	--trace-params \ # Shows parameter values in waveform
	--hierarchical \ # Hierarchical verilation: design is processed in a modular way (not too beneficial here, more beneficial for large rtl)
	--build \ # compiles the generated C++ model
	--unroll-count 256 \ # enaböes loop unrolling for performance, sets maximum limit to 256
	--Mdir $(VERIL_BUILD_DIR) \ # creates build directory
	-j `nproc` \ # build is done using all cpu cores \nproc returns number of available cores

.PHONY: lint
lint:
	verilator \ 
	--lint-only \ # runs verilator as a linter
	--timing \ # enables timing construct support
	--top-module $(TOP_MODULE) \ # sets top module as tb_apb_spi
	$(SRC_FILES) \

.PHONY: _init
_init:
	@mkdir -p $(BUILD_DIR)
	@mkdir -p $(VERIL_BUILD_DIR)

.PHONY: verilate
verilate: _init
	verilator \
	--binary \ # Parses .v & .sv files, generates C++ simulation model, Compiles C++ code, links everything into an executbale.
	$(VDEFS) \
	$(VFLAGS) \
	$(WAIVER) \ # lints warning expressions are called waivers, a way to tell verilator that warnings are known and reporting can be skipped on them
	--top-module $(TOP_MODULE) \
	$(SRC_FILES) \

.PHONY: simv
simv:
	@$(VERIL_BUILD_DIR)/V$(TOP_MODULE)

.PHONY: cleanv
cleanv:
	rm -rf $(VERIL_BUILD_DIR)

